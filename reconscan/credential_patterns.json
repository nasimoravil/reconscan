{
  "credentials": [
    {
      "name": "AWS Access Key",
      "pattern": "AKIA[0-9A-Z]{16}",
      "category": "cloud",
      "severity": "CRITICAL",
      "description": "AWS IAM access key exposed"
    },
    {
      "name": "AWS Secret Key",
      "pattern": "aws_secret_access_key[\\s]*[=:][\\s]*['\\\"]?([A-Za-z0-9/+=]{40})['\\\"]?",
      "category": "cloud",
      "severity": "CRITICAL",
      "description": "AWS secret key in code or config"
    },
    {
      "name": "Google API Key",
      "pattern": "AIza[0-9A-Za-z\\-_]{35}",
      "category": "cloud",
      "severity": "HIGH",
      "description": "Google Cloud API key exposed"
    },
    {
      "name": "Google Cloud Service Account",
      "pattern": "\"type\"\\s*:\\s*\"service_account\"",
      "category": "cloud",
      "severity": "CRITICAL",
      "description": "Google Cloud service account JSON"
    },
    {
      "name": "Stripe Secret Key",
      "pattern": "sk_live_[0-9a-zA-Z]{24,}",
      "category": "payment",
      "severity": "CRITICAL",
      "description": "Stripe live secret key exposed"
    },
    {
      "name": "Stripe Publishable Key",
      "pattern": "pk_live_[0-9a-zA-Z]{24,}",
      "category": "payment",
      "severity": "HIGH",
      "description": "Stripe publishable key exposed"
    },
    {
      "name": "GitHub Personal Access Token",
      "pattern": "gh[pousr]_[0-9A-Za-z]{36,}",
      "category": "vcs",
      "severity": "CRITICAL",
      "description": "GitHub PAT token exposed"
    },
    {
      "name": "GitHub OAuth Token",
      "pattern": "gho_[0-9A-Za-z]{36}",
      "category": "vcs",
      "severity": "CRITICAL",
      "description": "GitHub OAuth token"
    },
    {
      "name": "JWT Token",
      "pattern": "eyJ[A-Za-z0-9_\\-]+?\\.([A-Za-z0-9_\\-]+?)\\.([A-Za-z0-9_\\-]+)",
      "category": "auth",
      "severity": "MEDIUM",
      "description": "JWT token (requires analysis)"
    },
    {
      "name": "Private SSH Key",
      "pattern": "-----BEGIN [A-Z]+ PRIVATE KEY-----",
      "category": "crypto",
      "severity": "CRITICAL",
      "description": "Private key material exposed"
    },
    {
      "name": "SendGrid API Key",
      "pattern": "SG\\.[0-9a-zA-Z\\-_]{22,}",
      "category": "email",
      "severity": "HIGH",
      "description": "SendGrid API key exposed"
    },
    {
      "name": "Slack Token",
      "pattern": "xox[baprs]-[0-9]{10,13}-[0-9]{10,13}[a-zA-Z0-9\\-]*",
      "category": "communication",
      "severity": "CRITICAL",
      "description": "Slack workspace token"
    },
    {
      "name": "Slack Webhook",
      "pattern": "https://hooks\\.slack\\.com/services/T[0-9A-Z]+/B[0-9A-Z]+/[0-9A-Za-z]{24}",
      "category": "communication",
      "severity": "HIGH",
      "description": "Slack webhook URL"
    },
    {
      "name": "Mailchimp API Key",
      "pattern": "[0-9a-f]{32}-us[0-9]{1,2}",
      "category": "marketing",
      "severity": "HIGH",
      "description": "Mailchimp API key"
    },
    {
      "name": "Twilio API Key",
      "pattern": "SK[0-9a-f]{32}",
      "category": "communication",
      "severity": "HIGH",
      "description": "Twilio API key"
    },
    {
      "name": "Database Connection String",
      "pattern": "(mongodb|mysql|postgres|mssql)://[^\\s]+:[^\\s]+@[^\\s]+",
      "category": "database",
      "severity": "CRITICAL",
      "description": "Database credentials in connection string"
    },
    {
      "name": "Firebase API Key",
      "pattern": "AIza[0-9A-Za-z\\-_]{35}",
      "category": "cloud",
      "severity": "HIGH",
      "description": "Firebase API key"
    },
    {
      "name": "Basic Auth Credentials",
      "pattern": "Authorization[\\s]*:[\\s]*Basic[\\s]+[A-Za-z0-9+/]+=*",
      "category": "auth",
      "severity": "HIGH",
      "description": "HTTP Basic authentication header"
    },
    {
      "name": "API Key Variable",
      "pattern": "(api[_-]?key|apikey)[\\s]*[=:][\\s]*['\\\"][^'\\\"]{20,}['\\\"]",
      "category": "auth",
      "severity": "HIGH",
      "description": "Potentially exposed API key variable"
    },
    {
      "name": "Secret Variable",
      "pattern": "(secret|password|passwd)[\\s]*[=:][\\s]*['\\\"][^'\\\"]{12,}['\\\"]",
      "category": "auth",
      "severity": "HIGH",
      "description": "Potentially exposed secret variable"
    },
    {
      "name": "ACCESS_TOKEN",
      "pattern": "ACCESS_TOKEN[\\s]*[=:][\\s]*['\\\"]([^'\\\"]+)['\\\"]",
      "category": "auth",
      "severity": "MEDIUM",
      "description": "Access token variable exposed"
    },
    {
      "name": "Hardcoded Password",
      "pattern": "password[\\s]*[=:][\\s]*['\\\"]([^'\\\"]{8,})['\\\"]",
      "category": "auth",
      "severity": "CRITICAL",
      "description": "Hardcoded password found"
    },
    {
      "name": "PagerDuty API Key",
      "pattern": "U[0-9a-zA-Z]{20}",
      "category": "monitoring",
      "severity": "HIGH",
      "description": "PagerDuty integration key"
    },
    {
      "name": "NPM Token",
      "pattern": "npm_[0-9a-zA-Z]{36}",
      "category": "vcs",
      "severity": "HIGH",
      "description": "NPM authentication token"
    },
    {
      "name": "Twitter API Key",
      "pattern": "[a-zA-Z0-9]{25,}",
      "category": "social",
      "severity": "MEDIUM",
      "description": "Twitter/X API credentials (requires validation)"
    },
    {
      "name": "RSA Private Key",
      "pattern": "-----BEGIN RSA PRIVATE KEY-----",
      "category": "crypto",
      "severity": "CRITICAL",
      "description": "RSA private key exposure"
    },
    {
      "name": "OpenSSH Private Key",
      "pattern": "-----BEGIN OPENSSH PRIVATE KEY-----",
      "category": "crypto",
      "severity": "CRITICAL",
      "description": "OpenSSH private key exposure"
    },
    {
      "name": "PGP Private Key",
      "pattern": "-----BEGIN PGP PRIVATE KEY BLOCK-----",
      "category": "crypto",
      "severity": "CRITICAL",
      "description": "PGP private key exposure"
    },
    {
      "name": "Environment Variable SECRETS",
      "pattern": "process\\.env\\.([A-Z_]+SECRET|PASSWORD|TOKEN|KEY)",
      "category": "config",
      "severity": "MEDIUM",
      "description": "Environment variable possibly containing secrets"
    }
  ],
  "sensitive_headers": [
    "Authorization",
    "X-API-Key",
    "X-Auth-Token",
    "Access-Token",
    "Token",
    "X-Access-Token",
    "Cookie",
    "Set-Cookie"
  ],
  "sensitive_response_fields": [
    "api_key",
    "apiKey",
    "token",
    "access_token",
    "secret",
    "password",
    "private_key",
    "privateKey",
    "auth",
    "credentials",
    "jwt",
    "bearer"
  ],
  "config_files": [
    ".env",
    ".env.production",
    ".env.development",
    "config.json",
    "settings.json",
    "secrets.json",
    "application.properties",
    "application.yml",
    ".aws/credentials",
    ".ssh/config",
    "database.yml",
    "config/database.yml"
  ]
}
